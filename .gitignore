# =========================
# Unity (Unity 6 / LTS)
# =========================

# Generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Rr]ecordings/
UxmlGenerated/
UserSettings/       # 선택: 팀에서 공유 필요 없으면 ignore (필요하면 주석 처리)

# Unity crash reports
sysinfo.txt

# Asset meta handling (keep .meta, ignore meta for ignored folders is handled by folder ignore)

# =========================
# Addressables / Streaming
# =========================
# Addressables build output (optional to ignore; usually yes)
[Aa]ssets/[Aa]ddressableAssetsData/*/Build/
[Aa]ssets/[Aa]ddressableAssetsData/*/BuildTargetData/
[Aa]ssets/[Aa]ddressableAssetsData/*/RuntimeData/
# StreamingAssets often contains runtime data; if you store source files here, comment this out.
# [Aa]ssets/[Ss]treamingAssets/

# =========================
# Autogenerated / Cache
# =========================
# Shader cache / GI cache (usually under Library, but keep these safe)
*.pidb
*.booproj
*.svd
*.pdb
*.mdb

# =========================
# IDE / Editor
# =========================
# Visual Studio
.vs/
*.csproj
*.sln
*.suo
*.user
*.userprefs
*.unityproj
*.pidb
*.cache
*.ilk
*.tlog

# VS Code
.vscode/

# JetBrains Rider
.idea/
*.sln.iml

# JetBrains (general)
*.iml

# =========================
# OS / Misc
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =========================
# Package lock / UPM artifacts
# =========================
# Unity keeps packages in Packages/manifest.json and Packages/packages-lock.json (commit both)
# Do NOT ignore Packages/ by default.
# If you use npm/yarn inside the project for tools, add their ignores separately.

# =========================
# Optional: Temporary export artifacts
# =========================
*.unitypackage
*.apk
*.aab
*.app
*.exe
*.dmg
*.pkg
*.zip
*.rar